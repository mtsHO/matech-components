{
  "name": "@mateusho/matech-components",
  "version": "0.1.5",
  "description": "Shared React component library for Matech projects.",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mtsHO/matech-components.git"
  },
  "homepage": "https://github.com/mtsHO/matech-components#readme",
  "bugs": {
    "url": "https://github.com/mtsHO/matech-components/issues"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "storybook",
    "ui"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "test:typecheck": "tsc -p tsconfig.test.json",
    "validate": "npm run test:typecheck && npm test && npm run build",
    "release:check": "npm run validate && npm run build-storybook && npm run pack:check",
    "prepublishOnly": "npm run release:check",
    "pack:check": "npm pack --dry-run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "simple-git-hooks",
    "storybook": "WATCHPACK_POLLING=true storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run test:coverage"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.5.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.10"
  }
}
